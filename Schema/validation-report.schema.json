{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "validation-report.schema.json",
  "title": "CHIP-8 ROM Validation Report",
  "description": "Schema for the JSON generated by ValidationReport.to_json().",
  "type": "object",
  "required": [
    "command",
    "exit_code",
    "stdout",
    "stderr",
    "timed_out",
    "final_state",
    "state_match",
    "mismatch_details",
    "failure_reason",
    "success"
  ],
  "properties": {
    "command": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string" }
    },
    "exit_code": { "type": "integer" },
    "stdout": { "type": "string" },
    "stderr": { "type": "string" },
    "timed_out": { "type": "boolean" },
    "final_state": {
      "oneOf": [
        { "$ref": "cpu-state.schema.json" },
        { "type": "null" }
      ]
    },
    "state_match": { "type": "boolean" },
    "mismatch_details": {
      "type": "array",
      "items": { "type": "string" }
    },
    "failure_reason": {
      "type": ["string", "null"]
    },
    "success": { "type": "boolean" }
  },
  "additionalProperties": false
}
